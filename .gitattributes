# Normalize line endings to prevent the whole tree showing as modified.
# All text files are stored as LF in the repo; checkouts default to LF unless overridden below.
* text=auto eol=lf

# Source & config files — explicit LF
*.java   text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.xml    text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.sh     text eol=lf
*.bicep  text eol=lf
*.bicepparam text eol=lf
*.puml   text eol=lf
*.example    text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf

# PowerShell scripts use CRLF
*.ps1    text eol=crlf

# Binary files — never normalize
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.jar    binary
*.zip    binary

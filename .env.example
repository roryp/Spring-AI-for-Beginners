# Root .env — loaded by every module's start.sh / start.ps1
#
# Copy this file to `.env` in the repository root and fill in real values:
#   cp .env.example .env
#
# All modules (01–06) source this single root file. The per-module
# .env.example files document only the subset of variables each module
# consumes; you do NOT need to create per-module .env files.

# ---------------------------------------------------------------------------
# Microsoft Foundry — required by 01-introduction, 02-prompt-engineering,
# 03-rag, 04-tools, 05-mcp (server), 06-agents
#
# Two chat deployments:
#   AZURE_OPENAI_DEPLOYMENT       = reasoning model (gpt-5.2), used by 02 only
#   AZURE_OPENAI_FAST_DEPLOYMENT  = fast non-reasoning model (gpt-4o-mini),
#                                   used by 01, 03, 04, 05, 06
# ---------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-5.2
AZURE_OPENAI_FAST_DEPLOYMENT=gpt-4o-mini

# ---------------------------------------------------------------------------
# Microsoft Foundry Embeddings — required by 03-rag only
# ---------------------------------------------------------------------------
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ---------------------------------------------------------------------------
# GitHub Models — required by 00-quick-start only
# Create a token at https://github.com/settings/tokens (no scopes needed
# for GitHub Models inference).
# ---------------------------------------------------------------------------
GITHUB_TOKEN=your-github-token-here

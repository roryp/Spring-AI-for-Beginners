# 05-mcp/mcp-server uses Azure OpenAI for tool-augmented chat.
# 05-mcp/mcp-client talks to the server over MCP and does not need Azure creds.
# The start scripts load these values from the repository-root .env file.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-5

# 05-mcp/mcp-server uses Microsoft Foundry for the server-side aiMove tool.
# 05-mcp/mcp-client also needs these values at startup because the agent-chat
# path uses ChatClient; the direct board path alone does not use Azure creds.
# The start scripts load these values from the repository-root .env file.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_FAST_DEPLOYMENT=gpt-4o-mini
